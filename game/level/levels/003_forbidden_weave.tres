[gd_resource type="Resource" script_class="LevelSpec" format=3]

[ext_resource type="Script" path="res://level/LevelSpec.gd" id="1_spec"]
[ext_resource type="Script" path="res://level/objectives/ForbiddenZone.gd" id="2_zone"]
[ext_resource type="Script" path="res://level/objectives/FixedAnchor.gd" id="3_anchor"]

[sub_resource type="Resource" id="ForbiddenZone_003_A"]
script = ExtResource("2_zone")
objective_id = &"avoid_a"
edge_ids = Array[StringName]([&"beam"])
center = Vector2(200, 260)
radius = 35.0

[sub_resource type="Resource" id="ForbiddenZone_003_B"]
script = ExtResource("2_zone")
objective_id = &"avoid_b"
edge_ids = Array[StringName]([&"beam"])
center = Vector2(300, 260)
radius = 35.0

[sub_resource type="Resource" id="FixedAnchor_003_Left"]
script = ExtResource("3_anchor")
objective_id = &"left_anchor"
node_id = &"left"
position = Vector2(80, 260)
tolerance = 0.5

[sub_resource type="Resource" id="FixedAnchor_003_Right"]
script = ExtResource("3_anchor")
objective_id = &"right_anchor"
node_id = &"right"
position = Vector2(420, 260)
tolerance = 0.5

[resource]
script = ExtResource("1_spec")
level_id = &"003"
title = "Weave around quiet forbidden zones"
givens = {"nodes": [{"id": "left", "kind": 0, "position": [80.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 0, "position": [420.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}, {"position": [420.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
spatial_objectives = Array[Resource]([SubResource("ForbiddenZone_003_A"), SubResource("ForbiddenZone_003_B"), SubResource("FixedAnchor_003_Left"), SubResource("FixedAnchor_003_Right")])
reference_solution = {"nodes": [{"id": "left", "kind": 0, "position": [80.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 0, "position": [420.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [120.0, -180.0]}, {"position": [420.0, 260.0], "in_handle": [-120.0, -180.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
