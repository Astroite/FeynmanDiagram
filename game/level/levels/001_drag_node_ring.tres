[gd_resource type="Resource" script_class="LevelSpec" format=3]

[ext_resource type="Script" path="res://level/LevelSpec.gd" id="1_spec"]
[ext_resource type="Script" path="res://level/objectives/ObservationRing.gd" id="2_ring"]
[ext_resource type="Script" path="res://level/objectives/FixedAnchor.gd" id="3_anchor"]

[sub_resource type="Resource" id="ObservationRing_001"]
script = ExtResource("2_ring")
objective_id = &"ring_path"
edge_ids = Array[StringName]([&"beam"])
center = Vector2(210, 140)
radius = 46.0
thickness = 22.0

[sub_resource type="Resource" id="FixedAnchor_001"]
script = ExtResource("3_anchor")
objective_id = &"left_anchor"
node_id = &"left"
position = Vector2(80, 220)
tolerance = 0.5

[resource]
script = ExtResource("1_spec")
level_id = &"001"
title = "Drag the node through the ring"
givens = {"nodes": [{"id": "left", "kind": 0, "position": [80.0, 220.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 1, "position": [260.0, 220.0], "movement_constraint": null, "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 220.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}, {"position": [260.0, 220.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
spatial_objectives = Array[Resource]([SubResource("ObservationRing_001"), SubResource("FixedAnchor_001")])
reference_solution = {"nodes": [{"id": "left", "kind": 0, "position": [80.0, 220.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 1, "position": [300.0, 160.0], "movement_constraint": null, "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 220.0], "in_handle": [0.0, 0.0], "out_handle": [50.0, -50.0]}, {"position": [300.0, 160.0], "in_handle": [-60.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
