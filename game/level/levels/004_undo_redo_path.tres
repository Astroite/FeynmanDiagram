[gd_resource type="Resource" script_class="LevelSpec" format=3]

[ext_resource type="Script" path="res://level/LevelSpec.gd" id="1_spec"]
[ext_resource type="Script" path="res://level/objectives/ObservationRing.gd" id="2_ring"]
[ext_resource type="Script" path="res://level/objectives/ForbiddenZone.gd" id="3_zone"]
[ext_resource type="Script" path="res://level/objectives/FixedAnchor.gd" id="4_anchor"]

[sub_resource type="Resource" id="ObservationRing_004"]
script = ExtResource("2_ring")
objective_id = &"undo_ring"
edge_ids = Array[StringName]([&"beam"])
center = Vector2(260, 170)
radius = 60.0
thickness = 24.0

[sub_resource type="Resource" id="ForbiddenZone_004"]
script = ExtResource("3_zone")
objective_id = &"avoid_middle"
edge_ids = Array[StringName]([&"beam"])
center = Vector2(260, 260)
radius = 28.0

[sub_resource type="Resource" id="FixedAnchor_004_Left"]
script = ExtResource("4_anchor")
objective_id = &"left_anchor"
node_id = &"left"
position = Vector2(100, 260)
tolerance = 0.5

[sub_resource type="Resource" id="FixedAnchor_004_Right"]
script = ExtResource("4_anchor")
objective_id = &"right_anchor"
node_id = &"right"
position = Vector2(420, 260)
tolerance = 0.5

[resource]
script = ExtResource("1_spec")
level_id = &"004"
title = "Repair a path with undo and redo"
givens = {"nodes": [{"id": "left", "kind": 0, "position": [100.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 0, "position": [420.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [100.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}, {"position": [420.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
spatial_objectives = Array[Resource]([SubResource("ObservationRing_004"), SubResource("ForbiddenZone_004"), SubResource("FixedAnchor_004_Left"), SubResource("FixedAnchor_004_Right")])
reference_solution = {"nodes": [{"id": "left", "kind": 0, "position": [100.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right", "kind": 0, "position": [420.0, 260.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}], "edges": [{"id": "beam", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [100.0, 260.0], "in_handle": [0.0, 0.0], "out_handle": [90.0, -160.0]}, {"position": [420.0, 260.0], "in_handle": [-90.0, -160.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "beam:a", "node_id": "left", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "beam:b", "node_id": "right", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}]}
