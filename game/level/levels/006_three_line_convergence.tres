[gd_resource type="Resource" script_class="LevelSpec" format=3]

[ext_resource type="Script" path="res://level/LevelSpec.gd" id="1_spec"]
[ext_resource type="Script" path="res://level/objectives/FixedAnchor.gd" id="2_anchor"]

[sub_resource type="Resource" id="FixedAnchor_006_Top"]
script = ExtResource("2_anchor")
objective_id = &"top_to_center"
node_id = &"center"
position = Vector2(260, 220)
tolerance = 0.5
edge_id = &"top_line"
half_edge_index = 1
socket_id = &"socket_0"

[sub_resource type="Resource" id="FixedAnchor_006_Bottom"]
script = ExtResource("2_anchor")
objective_id = &"bottom_to_center"
node_id = &"center"
position = Vector2(260, 220)
tolerance = 0.5
edge_id = &"bottom_line"
half_edge_index = 1
socket_id = &"socket_1"

[sub_resource type="Resource" id="FixedAnchor_006_Right"]
script = ExtResource("2_anchor")
objective_id = &"right_to_center"
node_id = &"center"
position = Vector2(260, 220)
tolerance = 0.5
edge_id = &"right_line"
half_edge_index = 1
socket_id = &"socket_2"

[resource]
script = ExtResource("1_spec")
level_id = &"006"
title = "First three-line convergence"
givens = {"nodes": [{"id": "top_anchor", "kind": 0, "position": [80.0, 120.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "bottom_anchor", "kind": 0, "position": [80.0, 320.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right_anchor", "kind": 0, "position": [440.0, 220.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "center", "kind": 1, "position": [260.0, 220.0], "movement_constraint": null, "sockets": [{"id": "socket_0", "local_offset": [0.0, -16.0]}, {"id": "socket_1", "local_offset": [0.0, 0.0]}, {"id": "socket_2", "local_offset": [0.0, 16.0]}]}], "edges": [{"id": "top_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 120.0], "in_handle": [0.0, 0.0], "out_handle": [80.0, 0.0]}, {"position": [240.0, 190.0], "in_handle": [-70.0, -40.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "top_line:a", "node_id": "top_anchor", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "top_line:b", "node_id": "", "socket_id": "", "particle_id": "", "fermion_flow": 0}]}, {"id": "bottom_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 320.0], "in_handle": [0.0, 0.0], "out_handle": [80.0, 0.0]}, {"position": [240.0, 250.0], "in_handle": [-70.0, 40.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "bottom_line:a", "node_id": "bottom_anchor", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "bottom_line:b", "node_id": "", "socket_id": "", "particle_id": "", "fermion_flow": 0}]}, {"id": "right_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [440.0, 220.0], "in_handle": [0.0, 0.0], "out_handle": [-70.0, 0.0]}, {"position": [280.0, 220.0], "in_handle": [70.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "right_line:a", "node_id": "right_anchor", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "right_line:b", "node_id": "", "socket_id": "", "particle_id": "", "fermion_flow": 0}]}]}
spatial_objectives = Array[Resource]([SubResource("FixedAnchor_006_Top"), SubResource("FixedAnchor_006_Bottom"), SubResource("FixedAnchor_006_Right")])
reference_solution = {"nodes": [{"id": "top_anchor", "kind": 0, "position": [80.0, 120.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "bottom_anchor", "kind": 0, "position": [80.0, 320.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "right_anchor", "kind": 0, "position": [440.0, 220.0], "movement_constraint": "locked", "sockets": [{"id": "socket_0", "local_offset": [0.0, 0.0]}]}, {"id": "center", "kind": 1, "position": [260.0, 220.0], "movement_constraint": null, "sockets": [{"id": "socket_0", "local_offset": [0.0, -16.0]}, {"id": "socket_1", "local_offset": [0.0, 0.0]}, {"id": "socket_2", "local_offset": [0.0, 16.0]}]}], "edges": [{"id": "top_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 120.0], "in_handle": [0.0, 0.0], "out_handle": [80.0, 0.0]}, {"position": [260.0, 204.0], "in_handle": [-70.0, -40.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "top_line:a", "node_id": "top_anchor", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "top_line:b", "node_id": "center", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}]}, {"id": "bottom_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [80.0, 320.0], "in_handle": [0.0, 0.0], "out_handle": [80.0, 0.0]}, {"position": [260.0, 220.0], "in_handle": [-70.0, 40.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "bottom_line:a", "node_id": "bottom_anchor", "socket_id": "socket_0", "particle_id": "", "fermion_flow": 0}, {"id": "bottom_line:b", "node_id": "center", "socket_id": "socket_1", "particle_id": "", "fermion_flow": 0}]}, {"id": "right_line", "particle_id": "", "time_axis_dir": 0, "curve_points": [{"position": [440.0, 220.0], "in_handle": [0.0, 0.0], "out_handle": [-70.0, 0.0]}, {"position": [260.0, 236.0], "in_handle": [70.0, 0.0], "out_handle": [0.0, 0.0]}], "half_edges": [{"id": "right_line:a", "